# OpenAI-compat inference server (llama.cpp, Ollama, etc.)
EMBED_BASE_URL=https://api.theyuval.com/ai
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
# Optional: extra request headers e.g. Cloudflare Access
AI_HEADERS=
# Set to 0 if server uses a self-signed/local CA (e.g. Caddy local authority)
NODE_TLS_REJECT_UNAUTHORIZED=
